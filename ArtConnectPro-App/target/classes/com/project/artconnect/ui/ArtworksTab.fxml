<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.ArtworkController">
    <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>

    <TableView fx:id="artworkTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn"  text="Title"  prefWidth="180"/>
            <TableColumn fx:id="artistColumn" text="Artist" prefWidth="140"/>
            <TableColumn fx:id="typeColumn"   text="Type"   prefWidth="100"/>
            <TableColumn fx:id="priceColumn"  text="Price"  prefWidth="80"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
        </columns>
    </TableView>

    <Separator/>

    <Label fx:id="crudTitle" text="Add / Edit Artwork" style="-fx-font-weight:bold;"/>

    <GridPane fx:id="crudForm" hgap="10" vgap="6">
        <Label text="Title:"   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="formTitle"  promptText="Title"             prefWidth="180"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Artist:"  GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <ComboBox fx:id="formArtist" promptText="Select artist"      prefWidth="160"
                  GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <Label text="Type:"    GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="formType"   promptText="Painting, Sculpture" prefWidth="140"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Status:"  GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <ComboBox fx:id="formStatus"  prefWidth="140"
                  GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <Label text="Price:"   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="formPrice"  promptText="e.g. 1200.0"       prefWidth="120"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Year:"    GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <TextField fx:id="formYear"   promptText="e.g. 2022"          prefWidth="100"
                   GridPane.columnIndex="3" GridPane.rowIndex="2"/>

        <Label text="Medium:"  GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="formMedium" promptText="Oil, Bronze"        prefWidth="380"
                   GridPane.columnIndex="1" GridPane.rowIndex="3"
                   GridPane.columnSpan="3"/>
    </GridPane>

    <HBox fx:id="crudBox" spacing="10.0" alignment="CENTER_LEFT">
        <Button text="Add"        onAction="#handleCreate"
                style="-fx-background-color:#455A64;-fx-text-fill:white;-fx-background-radius:4;"/>
        <Button text="Update"     onAction="#handleUpdate"
                style="-fx-background-color:#455A64;-fx-text-fill:white;-fx-background-radius:4;"/>
        <Button text="Delete"     onAction="#handleDelete"
                style="-fx-background-color:#455A64;-fx-text-fill:white;-fx-background-radius:4;"/>
        <Button text="Reset Form" onAction="#handleResetForm"
                style="-fx-background-color:#455A64;-fx-text-fill:white;-fx-background-radius:4;"/>
        <Label fx:id="statusLabel" style="-fx-font-size:12px;"/>
    </HBox>
</VBox>
