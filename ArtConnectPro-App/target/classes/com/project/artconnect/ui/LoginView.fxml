<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="16"
      prefWidth="420" prefHeight="360"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.LoginController"
      style="-fx-background-color:white; -fx-padding:40;">

    <Label text="ArtConnect Pro"
           style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#455A64;"/>
    <Label text="Connectez-vous pour accéder à toutes les fonctionnalités"
           style="-fx-font-size:12px;-fx-text-fill:#888;" wrapText="true"/>

    <VBox spacing="8" maxWidth="300">
        <Label text="Email"/>
        <TextField fx:id="emailField" promptText="votre@email.fr"/>

        <Label text="Mot de passe"/>
        <PasswordField fx:id="passwordField" promptText="••••••••"/>

        <Label fx:id="errorLabel"
               style="-fx-text-fill:red;-fx-font-size:12px;"
               text="" wrapText="true"/>

        <Button text="Se connecter" onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color:#455A64;-fx-text-fill:white;
                       -fx-font-size:13px;-fx-background-radius:4;-fx-padding:8;"/>

        <Button text="Continuer sans connexion" onAction="#handleSkip"
                maxWidth="Infinity"
                style="-fx-background-color:transparent;-fx-text-fill:#455A64;
                       -fx-border-color:#455A64;-fx-border-radius:4;
                       -fx-font-size:12px;-fx-padding:6;"/>
    </VBox>

    <Separator maxWidth="300"/>

    <VBox spacing="2" alignment="CENTER"
          style="-fx-font-size:10px;-fx-text-fill:#bbb;">
        <Label text="Comptes de test :" style="-fx-font-size:11px;-fx-text-fill:#888;"/>
        <Label text="Organisateur : marie.dupont@artconnect.fr  /  admin123"/>
        <Label text="Artiste      : julien.mercier@art.fr  /  art_julienmercier"/>
        <Label text="Membre       : sophie.martin@email.fr  /  mem_sophiemartin"/>
    </VBox>
</VBox>
