<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.CommunityController">
    <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/></padding>

    <TableView fx:id="memberTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn"       text="Name"       prefWidth="200"/>
            <TableColumn fx:id="emailColumn"      text="Email"      prefWidth="220"/>
            <TableColumn fx:id="cityColumn"       text="City"       prefWidth="120"/>
            <TableColumn fx:id="membershipColumn" text="Membership" prefWidth="100"/>
        </columns>
    </TableView>

    <Separator/>
    <Label fx:id="crudTitle" text="Add / Edit Member" style="-fx-font-weight:bold;"/>

    <GridPane fx:id="crudForm" hgap="10" vgap="6">
        <Label text="Name:"       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="formName"      promptText="Full name"  prefWidth="180"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Email:"      GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <TextField fx:id="formEmail"     promptText="Email"      prefWidth="180"
                   GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <Label text="City:"       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="formCity"      promptText="City"       prefWidth="180"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Membership:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <ComboBox fx:id="formMembership" prefWidth="140"
                  GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <Label text="Phone:"      GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="formPhone"     promptText="Phone"      prefWidth="140"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Birth Year:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <TextField fx:id="formYear"      promptText="e.g. 1990"  prefWidth="100"
                   GridPane.columnIndex="3" GridPane.rowIndex="2"/>
    </GridPane>

    <HBox fx:id="crudBox" spacing="10.0" alignment="CENTER_LEFT">
        <Button fx:id="btnAdd"    text="Add"        onAction="#handleCreate"
                style="-fx-background-color:#455A64;-fx-text-fill:white;-fx-background-radius:4;"/>
        <Button fx:id="btnDelete" text="Delete"     onAction="#handleDelete"
                style="-fx-background-color:#455A64;-fx-text-fill:white;-fx-background-radius:4;"/>
        <Button text="Update"     onAction="#handleUpdate"
                style="-fx-background-color:#455A64;-fx-text-fill:white;-fx-background-radius:4;"/>
        <Button text="Reset Form" onAction="#handleResetForm"
                style="-fx-background-color:#455A64;-fx-text-fill:white;-fx-background-radius:4;"/>
        <Label fx:id="statusLabel" style="-fx-font-size:12px;"/>
    </HBox>
</VBox>
