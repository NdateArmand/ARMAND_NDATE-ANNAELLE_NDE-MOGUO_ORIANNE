<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="800.0" prefWidth="1200.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.MainController">

    <HBox alignment="CENTER_LEFT" style="-fx-background-color:#455A64;">
        <MenuBar style="-fx-background-color:transparent;">
            <Menu text="File"><MenuItem text="Exit" onAction="#handleExit"/></Menu>
            <Menu text="Help"><MenuItem text="About"/></Menu>
        </MenuBar>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnConnexion" text="Se connecter" onAction="#handleLogin"
                style="-fx-background-color:#1976D2;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:6 14;-fx-font-size:12px;">
            <HBox.margin><Insets right="8" top="4" bottom="4"/></HBox.margin>
        </Button>
        <Button fx:id="btnDeconnexion" text="Déconnexion" onAction="#handleLogout"
                style="-fx-background-color:#d32f2f;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:6 14;-fx-font-size:12px;">
            <HBox.margin><Insets right="8" top="4" bottom="4"/></HBox.margin>
        </Button>
    </HBox>

    <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab text="Discover">
            <fx:include fx:id="discoverTab" source="DiscoverTab.fxml"/>
        </Tab>
        <Tab text="Artists">
            <fx:include fx:id="artistsTab" source="ArtistsTab.fxml"/>
        </Tab>
        <Tab text="Artworks">
            <fx:include fx:id="artworksTab" source="ArtworksTab.fxml"/>
        </Tab>
        <Tab text="Galleries">
            <fx:include fx:id="galleriesTab" source="GalleriesTab.fxml"/>
        </Tab>
        <Tab text="Exhibitions">
            <fx:include fx:id="exhibitionsTab" source="ExhibitionsTab.fxml"/>
        </Tab>
        <Tab text="Workshops">
            <fx:include fx:id="workshopsTab" source="WorkshopsTab.fxml"/>
        </Tab>
        <Tab fx:id="communityTab" text="Community">
            <fx:include fx:id="communityTabContent" source="CommunityTab.fxml"/>
        </Tab>
    </TabPane>

    <HBox alignment="CENTER_RIGHT" prefHeight="28" style="-fx-background-color:#37474F;">
        <padding><Insets right="10" left="10"/></padding>
        <Label fx:id="statusLabel"
               text="ArtConnect Pro — Mode visiteur (non connecté)"
               style="-fx-text-fill:white;-fx-font-size:11px;"/>
    </HBox>
</VBox>
